# Solana RPC URL
#
# Overrides the endpoint for every network in the cluster switcher. Leave unset to
# use the public endpoints, which are heavily rate-limited and may reject browser
# writes with HTTP 403 — point this at a provider endpoint (Helius, QuickNode,
# Triton) for the network you actually test against.
#
# Exposed to the client and inlined at build time, so a production build must be
# rebuilt after changing it.
#
# Defaults when unset:
#   - Mainnet: https://api.mainnet-beta.solana.com
#   - Devnet:  https://api.devnet.solana.com
#   - Testnet: https://api.testnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=
